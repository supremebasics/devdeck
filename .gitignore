# All patterns are relative to this file — i.e. the repository root (./).
# A leading `/` means “only here at root”, not “any subfolder”.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env — keep the example tracked
.env*
!.env.example

# local runtime data (SQLite lives under ./data/)
/data/*.sqlite
/data/*.sqlite-*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
